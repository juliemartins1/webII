<!doctype html>
<html lang="pt-BR">
  <head>
    <title>MarketMVP | Criar conta</title>
    <%- include('_head') %>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <a href="/login" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Já tem uma conta?</a>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full max-w-2xl rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Crie sua conta</h1>
          <p class="mt-1 text-sm text-brand-700">Escolha um perfil de comprador ou vendedor.</p>

          <% if (typeof error !== 'undefined' && error) { %>
            <p class="mt-3 rounded-xl bg-coral-500/10 px-4 py-2 text-sm font-semibold text-coral-600"><%= error %></p>
          <% } %>

          <form method="POST" action="/signup" class="mt-5 grid gap-4 sm:grid-cols-2">
            <label class="block sm:col-span-2">
              <span class="mb-1 block text-sm font-medium">Nome completo</span>
              <input type="text" name="name" required
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block sm:col-span-2">
              <span class="mb-1 block text-sm font-medium">Email</span>
              <input type="email" name="email" required
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block sm:col-span-1">
              <span class="mb-1 block text-sm font-medium">Senha</span>
              <input type="password" name="password" required
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block sm:col-span-1">
              <span class="mb-1 block text-sm font-medium">Confirmar senha</span>
              <input type="password" name="confirm_password" required
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block sm:col-span-2">
              <span class="mb-1 block text-sm font-medium">Tipo de conta</span>
              <select name="tipo_usuario" class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring">
                <option value="comprador">Comprador</option>
                <option value="vendedor">Vendedor</option>
              </select>
            </label>
            <button type="submit" class="sm:col-span-2 rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Criar conta</button>
          </form>
        </section>
      </main>
    </div>
  </body>
</html>
