<!doctype html>
<html lang="pt-BR">
  <head>
    <title>MarketMVP | Painel administrativo</title>
  <%- include('_head') %>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-5 text-sm font-medium">
            <a href="/admin/users" class="font-semibold text-accent-600">Usuários</a>
            <a href="/admin/users/create" class="hover:text-accent-600">Criar usuário</a>
            <a href="/admin/logs" class="hover:text-accent-600">Logs</a>
            <form method="POST" action="/logout">
              <button type="submit" class="hover:text-accent-600">Sair</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Controle global da plataforma</p>
              <h1 class="mt-1 font-display text-3xl font-bold">Painel administrativo</h1>
              <p class="mt-2 max-w-2xl text-sm text-brand-700">Gerencie contas e desative acessos quando necessário.</p>
            </div>
            <div class="rounded-2xl bg-brand-100 px-4 py-3 text-sm font-semibold text-brand-800">
              Admin: <%= user.name %>
            </div>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas totais</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= users.length %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas ativas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= users.filter(u => u.ativo).length %></p>
            </div>
            <div class="rounded-2xl bg-brand-100 p-4">
              <p class="text-xs font-semibold uppercase tracking-wider">Contas desativadas</p>
              <p class="mt-2 font-display text-3xl font-bold"><%= users.filter(u => !u.ativo).length %></p>
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 class="font-display text-2xl font-bold">Lista de contas</h2>
              <p class="mt-1 text-sm text-brand-700">Compradores, vendedores e administradores.</p>
            </div>
            <form method="GET" action="/admin/users" class="flex gap-2">
              <input type="text" name="q" value="<%= search %>" placeholder="Buscar por nome, e-mail ou perfil"
                class="rounded-xl border border-brand-300 px-4 py-2 outline-none ring-accent-500 focus:ring" />
              <button type="submit" class="rounded-xl bg-accent-500 px-4 py-2 font-semibold text-white hover:bg-accent-600">Buscar</button>
            </form>
          </div>

          <div class="mt-4 overflow-x-auto rounded-2xl border border-brand-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-brand-100 text-brand-800">
                <tr>
                  <th class="px-4 py-3 font-semibold">Nome</th>
                  <th class="px-4 py-3 font-semibold">Perfil</th>
                  <th class="px-4 py-3 font-semibold">E-mail</th>
                  <th class="px-4 py-3 font-semibold">E-mail verificado</th>
                  <th class="px-4 py-3 font-semibold">Status</th>
                  <th class="px-4 py-3 font-semibold">Ações</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-200 bg-white">
                <% users.forEach(u => { %>
                <tr>
                  <td class="px-4 py-3 font-semibold"><%= u.name %></td>
                  <td class="px-4 py-3 capitalize">
                    <% if (u.tipo_usuario === 'admin') { %>Administrador
                    <% } else if (u.tipo_usuario === 'vendedor') { %>Vendedor
                    <% } else { %>Comprador<% } %>
                  </td>
                  <td class="px-4 py-3"><%= u.email %></td>
                  <td class="px-4 py-3">
                    <% if (u.email_verificado) { %>
                      <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Verificado</span>
                    <% } else { %>
                      <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-700">Pendente</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (u.ativo) { %>
                      <span class="rounded-full bg-accent-500/10 px-2 py-1 text-xs font-semibold text-accent-600">Ativa</span>
                    <% } else { %>
                      <span class="rounded-full bg-brand-200 px-2 py-1 text-xs font-semibold text-brand-700">Desativada</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <% if (u.id !== user.id) { %>
                      <form method="POST" action="/admin/users/<%= u.id %>/toggle">
                    <% if (u.ativo) { %>
                          <button type="submit" class="rounded-lg bg-coral-500 px-3 py-1.5 font-semibold text-white hover:bg-coral-600">Desativar</button>
                        <% } else { %>
                          <button type="submit" class="rounded-lg border border-brand-300 px-3 py-1.5 font-semibold hover:bg-brand-100">Reativar</button>
                        <% } %>
                      </form>
                    <% } else { %>
                      <span class="text-xs text-brand-500">Você</span>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
