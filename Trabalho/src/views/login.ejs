<!doctype html>
<html lang="pt-BR">
  <head>
    <title>MarketMVP | Entrar</title>
  <%- include('_head') %>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <a href="/signup" class="rounded-full border border-brand-300 px-4 py-2 text-sm font-semibold hover:bg-brand-100">Criar conta</a>
        </div>
      </header>

      <main class="mx-auto flex max-w-7xl items-center justify-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full max-w-md rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <h1 class="font-display text-3xl font-bold">Bem-vindo de volta</h1>
          <p class="mt-1 text-sm text-brand-700">Entre com seu e-mail e senha.</p>

          <% if (verified) { %>
            <p class="mt-3 rounded-xl bg-accent-500/10 px-4 py-2 text-sm font-semibold text-accent-600">E-mail verificado! Faça login.</p>
          <% } %>
          <% if (typeof error !== 'undefined' && error) { %>
            <p class="mt-3 rounded-xl bg-coral-500/10 px-4 py-2 text-sm font-semibold text-coral-600"><%= error %></p>
          <% } %>

          <form method="POST" action="/login" class="mt-5 space-y-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Email</span>
              <input type="email" name="email" required placeholder="you@example.com"
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <label class="block">
              <span class="mb-1 block text-sm font-medium">Senha</span>
              <input type="password" name="password" required placeholder="********"
                class="w-full rounded-xl border border-brand-300 px-4 py-2.5 outline-none ring-coral-500 focus:ring" />
            </label>
            <button type="submit" class="w-full rounded-xl bg-brand-900 px-4 py-2.5 font-semibold text-brand-50 hover:bg-brand-800">Entrar</button>
          </form>
          <p class="mt-4 text-center text-sm text-brand-700">Novo no marketplace? <a href="/signup" class="font-semibold text-accent-600">Crie sua conta</a></p>
        </section>
      </main>
    </div>
  </body>
</html>
