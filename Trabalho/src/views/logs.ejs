<!doctype html>
<html lang="pt-BR">
  <head>
    <title>MarketMVP | Logs de auditoria</title>
    <%- include('_head') %>
  </head>
  <body class="font-body bg-brand-50 text-brand-900">
    <div class="min-h-screen grid-bg">
      <header class="border-b border-brand-200/80 bg-white/75 backdrop-blur">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="font-display text-xl font-bold">MarketMVP</a>
          <nav class="flex items-center gap-5 text-sm font-medium">
            <a href="/admin/users" class="hover:text-accent-600">Usuários</a>
            <a href="/admin/users/create" class="hover:text-accent-600">Criar usuário</a>
            <a href="/admin/logs" class="font-semibold text-accent-600">Logs</a>
            <form method="POST" action="/logout">
              <button type="submit" class="hover:text-accent-600">Sair</button>
            </form>
          </nav>
        </div>
      </header>

      <main class="mx-auto max-w-7xl space-y-6 px-4 py-8 sm:px-6 lg:px-8">
        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Auditoria</p>
          <h1 class="mt-1 font-display text-3xl font-bold">Logs de ações</h1>
          <p class="mt-2 text-sm text-brand-700">Registro de todas as operações não-GET realizadas na plataforma.</p>
        </section>

        <section class="rounded-3xl border border-brand-200 bg-white p-6 shadow-sm">
          <div class="overflow-x-auto rounded-2xl border border-brand-200">
            <table class="min-w-full text-left text-sm">
              <thead class="bg-brand-100 text-brand-800">
                <tr>
                  <th class="px-4 py-3 font-semibold">Data/Hora</th>
                  <th class="px-4 py-3 font-semibold">Usuário</th>
                  <th class="px-4 py-3 font-semibold">Método</th>
                  <th class="px-4 py-3 font-semibold">Rota</th>
                  <th class="px-4 py-3 font-semibold">Resumo</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-200 bg-white">
                <% logs.forEach(log => { %>
                <tr>
                  <td class="px-4 py-3 whitespace-nowrap text-brand-600"><%= log.created_at %></td>
                  <td class="px-4 py-3">
                    <% if (log.user_name) { %>
                      <span class="font-semibold"><%= log.user_name %></span>
                      <span class="block text-xs text-brand-500"><%= log.user_email %></span>
                    <% } else { %>
                      <span class="text-brand-400">Anônimo</span>
                    <% } %>
                  </td>
                  <td class="px-4 py-3">
                    <span class="rounded-full bg-brand-100 px-2 py-1 text-xs font-semibold"><%= log.method %></span>
                  </td>
                  <td class="px-4 py-3 font-mono text-xs"><%= log.route %></td>
                  <td class="px-4 py-3"><%= log.resumo %></td>
                </tr>
                <% }) %>
                <% if (logs.length === 0) { %>
                <tr>
                  <td colspan="5" class="px-4 py-6 text-center text-brand-500">Nenhum log registrado.</td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
